# GitLab Configuration
GITLAB_URL=https://gitlab.espressif.cn:6688
GITLAB_TOKEN=your_gitlab_token_here

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret_here

# Server Configuration
